# Supabase Postgres connection string (Project Settings -> Database -> Connection string -> URI)
# Use the "connection pooling" URI for serverless/dev, port 6543, with ?pgbouncer=true
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@[PROJECT-REF].supabase.co:5432/postgres"

# Supabase project (used server-side for verifying auth tokens later)
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Fallback Gemini key used ONLY if a user hasn't provided their own yet (optional, can leave blank)
GEMINI_API_KEY=""

PORT=8787
CLIENT_ORIGIN="http://localhost:5173"
